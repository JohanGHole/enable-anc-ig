       ] ;
       fhir:ImplementationGuide.definition.resource.name [ fhir:value "ENABLE ANC Encounter (visit)" ] ;
       fhir:ImplementationGuide.definition.resource.description [ fhir:value "One ANC visit for the woman. status = finished for a visit that happened; status = planned for the next scheduled visit. period.start carries the date. serviceProvider references the facility (used by the middleware to derive the DHIS2 orgUnit for the enrolment and every event)." ] ;
       fhir:ImplementationGuide.definition.resource.exampleBoolean [ fhir:value "false"^^xsd:boolean ]
