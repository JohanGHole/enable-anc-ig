# - resource -------------------------------------------------------------------

<http://fhi.no/enable/anc/ImplementationGuide/enable.anc.ig> a fhir:ImplementationGuide ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "enable.anc.ig"] ;
  fhir:Resource.language [ fhir:value "en"] ;
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\"><p class=\"res-header-id\"><b>Generated Narrative: ImplementationGuide enable.anc.ig</b></p><a name=\"enable.anc.ig\"> </a><a name=\"hcenable.anc.ig\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\">Language: en</p></div><h2>EnableAncIG</h2><p>The official URL for this implementation guide is: </p><pre>http://fhi.no/enable/anc/ImplementationGuide/enable.anc.ig</pre><div><p>A deliberately minimal FHIR contract for the ENABLE programme. It defines exactly what an EMR (Bahmni, PulseTech, ...) must send to the ENABLE FHIR-native middleware that sits in front of DHIS2: one Bundle per patient, with an ANC Patient, the facility (Organization) whose identifier maps to a DHIS2 org unit, one or more ANC Encounters, and a small set of Observations, so a woman's ANC visits flow into the DHIS2 ANC tracker and drive the SMS gateway. Standalone profiles reference WHO SMART ANC (DAK) codes plus LOINC and SNOMED. Integration contract, not a clinical IG.</p>\n</div></div>"
  ] ;
  fhir:ImplementationGuide.url [ fhir:value "http://fhi.no/enable/anc/ImplementationGuide/enable.anc.ig"] ;
  fhir:ImplementationGuide.version [ fhir:value "0.2.0"] ;
  fhir:ImplementationGuide.name [ fhir:value "EnableAncIG"] ;
  fhir:ImplementationGuide.title [ fhir:value "ENABLE ANC Interoperability IG"] ;
  fhir:ImplementationGuide.status [ fhir:value "draft"] ;
  fhir:ImplementationGuide.date [ fhir:value "2026-07-07T17:20:37+00:00"^^xsd:dateTime] ;
  fhir:ImplementationGuide.publisher [ fhir:value "Devotta"] ;
  fhir:ImplementationGuide.contact [
     fhir:index -1 ;
     fhir:ContactDetail.name [ fhir:value "Devotta" ] ;
     fhir:ContactDetail.telecom [
       fhir:index -1 ;
       fhir:ContactPoint.system [ fhir:value "url" ] ;
       fhir:ContactPoint.value [ fhir:value "https://www.devotta.no/" ]
     ], [
       fhir:index -1 ;
       fhir:ContactPoint.system [ fhir:value "email" ] ;
       fhir:ContactPoint.value [ fhir:value "johan@devotta.no" ]
     ]
  ] ;
  fhir:ImplementationGuide.description [ fhir:value "A deliberately minimal FHIR contract for the ENABLE programme. It defines exactly what an EMR (Bahmni, PulseTech, ...) must send to the ENABLE FHIR-native middleware that sits in front of DHIS2: one Bundle per patient, with an ANC Patient, the facility (Organization) whose identifier maps to a DHIS2 org unit, one or more ANC Encounters, and a small set of Observations, so a woman's ANC visits flow into the DHIS2 ANC tracker and drive the SMS gateway. Standalone profiles reference WHO SMART ANC (DAK) codes plus LOINC and SNOMED. Integration contract, not a clinical IG."] ;
