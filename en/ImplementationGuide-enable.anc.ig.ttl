       ] ;
       fhir:ImplementationGuide.definition.resource.name [ fhir:value "ENABLE ANC Bundle: single-visit example" ] ;
       fhir:ImplementationGuide.definition.resource.description [ fhir:value "A complete first-ANC-visit payload for one patient: Patient + Facility + a finished and a planned Encounter + pregnancy-level Observations (LMP, EDD) + visit-level Observations (GA, Visit Number) for that finished visit." ] ;
       fhir:ImplementationGuide.definition.resource.exampleCanonical [
